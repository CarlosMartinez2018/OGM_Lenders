# ─── AcentoPartners Email Classifier — Environment Config ────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL via Docker (docker-compose up postgres -d)
# Port 5433 on host maps to 5432 inside the container.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# ─── Ollama LLM ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Set to true to run without Ollama (keyword-based mock classifier)
USE_MOCK_LLM=true

# ─── Email Paths ─────────────────────────────────────────────────────────────
SAMPLE_EMAILS_PATH=./sample_emails

# ─── Microsoft Graph API (Phase 2: Outlook Integration) ──────────────────────
# Register an app at https://portal.azure.com > App registrations
# Required permissions: Mail.Read (Application)
AZURE_TENANT_ID=41725d73-0268-471b-b1ee-ff56be3e5b16
AZURE_CLIENT_ID=7dfd4cdd-5ba6-433c-a6c5-809a07e0a1ef
AZURE_CLIENT_SECRET=Ldt8Q~Mo9P5qThk_Kaz3ncY_T52oRhG~Yyn_VbBC
OUTLOOK_MAILBOX=lender-insurance@acentopartners.com
OUTLOOK_POLL_INTERVAL=60

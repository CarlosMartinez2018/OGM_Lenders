# =============================================================
# AcentoPartners Email Classifier - Configuration
# =============================================================

# --- App ---
APP_NAME=AcentoPartners Email Classifier
DEBUG=true
LOG_LEVEL=INFO

# --- Ollama LLM ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Alternative models: mistral:7b, llama3.1:70b (if you have GPU)

# --- Email Ingestion ---
# Path to folder with sample .eml files for batch testing
SAMPLE_EMAILS_PATH=./sample_emails

# --- Microsoft Graph API (Outlook Integration) ---
# Register app at https://portal.azure.com > App registrations
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
# Mailbox to monitor (shared mailbox or user)
OUTLOOK_MAILBOX=waivers@acentopartners.com
# Polling interval in seconds (for non-webhook mode)
OUTLOOK_POLL_INTERVAL=60

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/classifications.db
